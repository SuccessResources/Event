{
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/",
      "has": [
        {
          "type": "query",
          "key": "city"
        }
      ],
      "dest": "/redirect.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/kuala-lumpur|/malaga|/warsaw|/london|/berlin|/johor-bahru|/geneva|/madrid|/rotterdam|/kuala-lumpur-oct|/birmingham|/brussels",
      "dest": "/index.html"
    }
  ]
}
